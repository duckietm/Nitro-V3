        "dompurify": "^3.4.1",
        "emoji-mart": "^5.6.0",
        "emoji-toolkit": "10.0.0",
        "framer-motion": "^12.38.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-icons": "^5.5.0",
